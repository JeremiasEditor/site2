# Senha do painel de administração (/admin)
ADMIN_PASSWORD=troque-esta-senha

# Ambiente do Next.js
NODE_ENV=production

# ------------------------------------------------------------------
# Banco de dados (PostgreSQL do Railway)
# ------------------------------------------------------------------
# No Railway, ao adicionar um banco PostgreSQL, a variável DATABASE_URL
# é injetada automaticamente. Use "Reference Variable" para vinculá-la
# ao serviço do site. Localmente, deixe em branco para usar arquivos.
# DATABASE_URL=postgresql://usuario:senha@host:5432/railway

# Defina como "true" apenas se conectar pela URL PÚBLICA do banco
# (proxy). Pela rede interna do Railway (.railway.internal) deixe vazio.
# DATABASE_SSL=false

# ------------------------------------------------------------------
# Arquivos de mídia (vídeos) — Volume persistente do Railway
# ------------------------------------------------------------------
# Pasta onde os arquivos de vídeo são gravados. O padrão é data/media
# dentro do projeto. No Railway, adicione um Volume com Mount Path
# /app/data para que esses arquivos NÃO sejam apagados a cada deploy.
# MEDIA_DIR=/app/data/media
